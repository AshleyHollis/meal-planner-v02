{
  "name": "meal-planner-v02",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web"
  ],
  "scripts": {
    "dev:web": "npm --prefix apps/web run dev",
    "build:web": "npm --prefix apps/web run build",
    "lint:web": "npm --prefix apps/web run lint",
    "typecheck:web": "npm --prefix apps/web run typecheck",
    "dev:api": "python -m uvicorn app.main:app --app-dir apps/api --host 127.0.0.1 --port 8000",
    "dev:worker": "python apps/worker/app/main.py",
    "test:api": "cmd /c \"cd apps\\\\api && python -m pytest tests\"",
    "test:worker": "cmd /c \"cd apps\\\\worker && python -m pytest tests\""
  }
}
