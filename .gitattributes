# Line endings: enforce LF everywhere for cross-platform consistency
* text=auto
*.py text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.html text eol=lf
*.css text eol=lf
*.sh text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf

# Binary files
*.db binary
*.pyc binary
*.egg-info binary

# Squad: union merge for append-only team state files
.squad/decisions.md merge=union
.squad/agents/*/history.md merge=union
.squad/log/** merge=union
.squad/orchestration-log/** merge=union
